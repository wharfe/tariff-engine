{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*.ts", "cli/**/*.ts", "compiler/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
